# clean base image containing only comfyui, comfy-cli and comfyui-manager
FROM runpod/worker-comfyui:5.8.4-base

# Overwrite the handler in the image with the one from this repository.
COPY handler.py /handler.py

# install custom nodes into comfyui
RUN git clone https://github.com/rgthree/rgthree-comfy /comfyui/custom_nodes/rgthree-comfy && cd /comfyui/custom_nodes/rgthree-comfy && (git checkout 683836c46e898668936c433502504cc0627482c5 2>/dev/null || (git fetch origin 683836c46e898668936c433502504cc0627482c5 --depth=1 && git checkout 683836c46e898668936c433502504cc0627482c5) || echo "WARN: commit 683836c46e898668936c433502504cc0627482c5 unreachable in https://github.com/rgthree/rgthree-comfy, falling back to default branch HEAD")

RUN comfy node install --exit-on-fail was-ns@3.0.1 --mode remote || (echo "WARN: was-ns@3.0.1 unavailable in registry, falling back to latest" >&2 && comfy node install --exit-on-fail was-ns --mode remote)

RUN git clone https://github.com/crystian/ComfyUI-Crystools.git /comfyui/custom_nodes/ComfyUI-Crystools
RUN pip install --no-cache-dir -r /comfyui/custom_nodes/ComfyUI-Crystools/requirements.txt

RUN git clone https://github.com/xesx/ComfyUI-QwenVL-xesx.git /comfyui/custom_nodes/ComfyUI-QwenVL-xesx
RUN pip install --no-cache-dir -r /comfyui/custom_nodes/ComfyUI-QwenVL-xesx/requirements.txt
